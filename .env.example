# .env.example — copy to .env and fill in values before running docker compose
#
# Required:
RECURSIVE_API_KEY=sk-your-openai-key-here

# Optional — defaults shown:
RECURSIVE_API_BASE=https://api.openai.com/v1
RECURSIVE_MODEL=gpt-4o-mini
RECURSIVE_PROVIDER_TYPE=openai
RECURSIVE_MAX_STEPS=32
RECURSIVE_TEMPERATURE=0.2

# HTTP server
RECURSIVE_HTTP_AUTH_KEYS=

# Cloud storage — leave blank to use local-mode defaults
RECURSIVE_REDIS_URL=
RECURSIVE_S3_BUCKET=
